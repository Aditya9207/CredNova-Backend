# CredNova Backend Configuration

# MongoDB Connection String (Required)
# Format: mongodb://[username:password@]host[:port]/[database][?options]
MONGO_URI=mongodb://localhost:27017/crednova

# --- Optional Configurations ---

# External Credit Scoring Model URL (Defaults to a production endpoint if not set)
# CREDIT_MODEL_URL=https://your-model.example.com/predict

# Admin API Key for protected routes
# CREDIT_ADMIN_API_KEY=your_admin_secret_key

# OpenAI Integration (Required for AI-powered spending narratives and tips)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_INSIGHTS_MODEL=gpt-4o-mini

# Ollama Local LLM (Used for generating remarks)
# Note: Ensure Ollama is running locally with the 'mistral' model installed
# OLLAMA_MODEL=mistral
